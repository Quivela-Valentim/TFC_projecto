# Copia este ficheiro para ".env" (mesma pasta) e preenche com as tuas credenciais reais.
# O ficheiro ".env" nunca deve ser enviado para um repositório partilhado (já está no .gitignore).

# Ligação directa à tua base MySQL real, com resumo_mercados/livros_de_ordens já existentes.
DB_ENGINE=mysql.connector.django
DB_NAME=meubanco_bodiva
DB_USER=o_teu_utilizador_mysql
DB_PASSWORD=a_tua_password_mysql
DB_HOST=localhost
DB_PORT=3306

# Deixa em branco (ou remove estas 6 linhas) para usar SQLite local em vez de MySQL —
# funciona, mas sem dados de mercado (as tabelas resumo_mercados/livros_de_ordens não existirão).
